{
  "name": "password-hasher-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for Argon2id hashing via Rust + wasm_bindgen.",
  "scripts": {
    "dev": "wrangler dev --config workers/password-hasher/wrangler.jsonc",
    "dev:bench": "wrangler dev --config workers/benchmark-proxy/wrangler.jsonc --port 8790",
    "typecheck": "tsc --build --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:core": "cargo test -p password-hasher",
    "test:integration": "vitest run benchmark/src/integration.test.ts",
    "test:compliance": "vitest run benchmark/src/compliance.test.ts",
    "test:all": "cargo test -p password-hasher && vitest run",
    "benchmark": "tsx benchmark/src/runner.ts",
    "benchmark:full": "tsx benchmark/src/runner.ts --concurrency 1,2,5,10,20 --requests 100"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "packageManager": "yarn@4.13.0"
}
